                "<span class=\"selectableFont\">\u0712\u0730\u072a \u0720\u0718\u073a\u071d\u072c\u0733\u0710</span> travelling companion",
                "<span class=\"selectableFont\">\u0712\u0730\u072a \u0721\u0736\u0720\u071f\u0733\u0710</span> counselor",
