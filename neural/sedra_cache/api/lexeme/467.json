        "glosses": {
            "English": [
                "son",
                "Kth. f. wife of a priest",
                "human being, kindred",
                "close companion",
                "<span class=\"selectableFont\">\u0712\u0730\u072a \u0725\u0733\u0720\u0721\u0733\u0710</span> layman",
