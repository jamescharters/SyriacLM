                "<span class=\"selectableFont\">\u0712\u0730\u072a \u0713\u0736\u0722\u0723\u0733\u0710</span> kindred",
                "<span class=\"selectableFont\">\u0712\u0730\u072a \u0712\u0736\u0723\u072c\u072a\u0733\u071d\u0733\u0710</span> reverse",
