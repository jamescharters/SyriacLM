                "<span class=\"selectableFont\">\u0712\u0730\u072a \u0712\u0736\u0723\u072c\u072a\u0733\u0710\u073a\u071d\u072c</span> backwards",
                "<span class=\"selectableFont\">\u0712\u0730\u072a \u071a\u073a\u0710\u072a\u0308</span><span class=\"selectableFont\">\u0736\u0710</span> noble, freeborn",
                "<span class=\"selectableFont\">\u0712\u0730\u072a \u0725\u0736\u0722\u071d\u0733\u0722\u0733\u0710</span> familiar friend",
                "<span class=\"selectableFont\">\u0712\u0730\u072a \u0721\u0715\u073a\u071d\u0722\u0331</span><span class=\"selectableFont\">\u072c\u0733\u0710</span> citizen",
