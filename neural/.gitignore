# Self-contained ignore rules for the neural/ sub-project.
# Keeps large/derived/licensed artifacts out of git without touching the parent
# repo's .gitignore.

# Trained checkpoints and exported encoders
*.pt
*.safetensors
checkpoints/
runs/

# Aggregated / derived corpora (regenerated by aggregate.py; default lives in
# ~/.cache/syriac-neural but allow a local ./data too)
data/
*.jsonl
*.arrow

# SEDRA data now lives in the shared corpora/ package (tracked there for
# reproducibility, except the large corpora/sedra_cache/sedra.db). SEDRA is
# "MIT with restrictions": academic use only, no redistribution of altered
# versions, cite Kiraz. See neural/docs/DATA.md and corpora/.

# Results manifest is a regenerable cache (the single source of truth for paper
# numbers is rebuilt by results.py; the rendered paper/tables/*.tex are committed,
# mirroring how the parent commits tables but not paper_results.txt).
paper/results.json

# Python noise
__pycache__/
*.pyc
.ipynb_checkpoints/
